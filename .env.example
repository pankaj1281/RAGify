# Environment variables for local development
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# LLM Provider – choose one of: ollama | groq | openai
# ---------------------------------------------------------------------------
# "ollama" (default) – free, runs locally, no API key needed.
#   Install Ollama: https://ollama.com  →  ollama pull llama2  →  ollama serve
# "groq"             – free cloud API, fast inference.
#   Get a free key:  https://console.groq.com
# "openai"           – OpenAI ChatCompletion (requires paid API key).
#   https://platform.openai.com
LLM_PROVIDER=ollama

# Ollama (free, local – https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama2

# Groq (free API – https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# OpenAI (paid – https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.2

# Embedding model (local, free – no API key required)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./data/embedding_cache

# Vector store
FAISS_INDEX_PATH=./data/faiss_index
TOP_K=5

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Data paths
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# Logging
LOG_LEVEL=INFO
