# Environment variables for local development
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# LLM Provider – choose one of: nvidia | groq | openai
# ---------------------------------------------------------------------------
# "nvidia" (default) – free NVIDIA cloud API, OpenAI-compatible endpoint.
#   Get a free key:  https://build.nvidia.com
# "groq"             – free cloud API, fast inference.
#   Get a free key:  https://console.groq.com
# "openai"           – OpenAI ChatCompletion (requires paid API key).
#   https://platform.openai.com
LLM_PROVIDER=nvidia

# Groq (free API – https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# NVIDIA (free API – https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama3-70b-instruct

# OpenAI (paid – https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.2

# Embedding model (local, free – no API key required)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./data/embedding_cache

# Vector store
FAISS_INDEX_PATH=./data/faiss_index
TOP_K=5

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Data paths
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# Logging
LOG_LEVEL=INFO
